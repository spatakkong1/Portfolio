  @keyframes glitch1 {
    0%, 90%, 100% { transform: translateX(0); opacity: 0; }
    92% { transform: translateX(-3px); opacity: 0.7; }
    94% { transform: translateX(3px); opacity: 0.7; }
    96% { transform: translateX(-3px); opacity: 0; }
  }

  @keyframes glitch2 {
